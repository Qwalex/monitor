{
  "name": "bybit-balance-monitor",
  "version": "1.0.0",
  "description": "Monitor Bybit account balances with web interface and Telegram bot",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-ui",
    "copy-ui": "node -e \"const fs=require('fs');fs.cpSync('src/ui','dist/ui',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "bybit-api": "^4.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.64.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
