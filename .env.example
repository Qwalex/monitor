# Копируйте в .env и заполните. На Railway задайте те же переменные в Variables.

# Порт (на Railway задаётся автоматически, локально по умолчанию 3000)
PORT=3000

# Префикс URL без завершающего слэша, например /monitor за прокси (локально оставьте пустым)
BASE_PATH=

# MongoDB (обязательно). Локально: mongodb://127.0.0.1:27017/monitor
# Railway: после добавления плагина MongoDB подставьте переменную из панели (часто MONGO_URL — приложение читает и её).
MONGODB_URI=mongodb://127.0.0.1:27017/monitor

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

VK_ACCESS_TOKEN=
VK_PEER_ID=
VK_GROUP_ID=

# Опционально: токен для защиты endpoint webhook от Railway.
# Передавайте его в Railway webhook как:
# Authorization: Bearer <RAILWAY_WEBHOOK_TOKEN>
# или заголовком x-railway-token.
RAILWAY_WEBHOOK_TOKEN=

# Опционально: абсолютный путь к .env на хосте (Docker)
# MONITOR_DOTENV=
